{
    "id": "whisperer",
    "name": "Whisperer",
    "description": "Push-to-talk dictation: records your voice, transcribes it locally with whisper.cpp, and types the result at the cursor",
    "version": "0.2.0",
    "author": "dwright",
    "type": "widget",
    "capabilities": ["dankbar-widget"],
    "component": "./Whisperer.qml",
    "icon": "mic",
    "settings": "./WhispererSettings.qml",
    "requires_dms": ">=1.0.0",
    "requires": ["pw-record", "pw-cli", "wtype", "whisper-cli", "secret-tool"],
    "permissions": ["settings_read", "settings_write", "process"]
}
